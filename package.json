{
  "name": "glion-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Modern Typescript HL7v2 workspace",
  "keywords": [
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "nodejs",
    "typescript"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": "rethinkhealth/glion.git",
  "type": "module",
  "scripts": {
    "bench": "turbo run bench",
    "bench:ci": "pnpm --filter @glion/benchmarks bench",
    "build": "turbo run build",
    "check": "ultracite check",
    "check-types": "turbo run check-types",
    "check:readmes": "turbo run check:readme",
    "ci:install": "pnpm install --no-frozen-lockfile",
    "ci:publish": "pnpm recursive publish --no-git-checks --access public",
    "ci:update": "pnpm --recursive update",
    "ci:version": "pnpm changeset version",
    "clean": "rimraf packages/*/dist packages/*/node_modules packages/*/coverage packages/*/.turbo node_modules packages/*/tsconfig.tsbuildinfo",
    "dev": "turbo run dev",
    "fix": "ultracite fix",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "publint": "turbo run publint",
    "syncpack": "npx syncpack lint",
    "syncpack:fix": "npx syncpack fix",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:watch": "turbo run test -- --watch"
  },
  "dependencies": {
    "syncpack": "14.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@glion/tsconfig": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "oxfmt": "^0.44.0",
    "oxlint": "1.51.0",
    "pkg-pr-new": "0.0.66",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "ultracite": "7.4.0"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "ultracite fix"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
