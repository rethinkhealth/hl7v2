{
  "name": "hl7v2-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Modern Typescript HL7v2 workspace",
  "keywords": [
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "nodejs",
    "typescript"
  ],
  "homepage": "https://www.rethinkhealth.io/hl7v2/docs",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": "rethinkhealth/hl7v2.git",
  "type": "module",
  "scripts": {
    "bench": "turbo run bench",
    "bench:ci": "pnpm --filter @rethinkhealth/benchmarks bench",
    "build": "turbo run build",
    "check": "ultracite check",
    "check-types": "turbo run check-types",
    "ci:install": "pnpm install --no-frozen-lockfile",
    "ci:publish": "pnpm recursive publish --no-git-checks --access public",
    "ci:update": "pnpm --recursive update",
    "ci:version": "pnpm changeset version",
    "clean": "rimraf packages/*/dist packages/*/node_modules packages/*/coverage packages/*/.turbo node_modules packages/*/tsconfig.tsbuildinfo",
    "dev": "turbo run dev",
    "fix": "ultracite fix",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "syncpack": "npx syncpack",
    "syncpack:fix": "npx syncpack fix-mismatches && npx syncpack set-semver-ranges",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:watch": "turbo run test -- --watch"
  },
  "dependencies": {
    "syncpack": "13.0.4"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@rethinkhealth/hl7v2-cli": "workspace:*",
    "@rethinkhealth/tsconfig": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "only-allow": "^1.2.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.56.0",
    "rimraf": "^6.1.2",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0"
}
