{
  "name": "@glion/util-query",
  "version": "0.15.3",
  "description": "Query HL7v2 AST nodes by HL7 location paths",
  "keywords": [
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "nodejs",
    "typescript"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/util-query"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "check:readme": "glion-check-readme",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "publint": "publint --strict"
  },
  "dependencies": {
    "@glion/ast": "workspace:*",
    "@glion/utils": "workspace:*"
  },
  "devDependencies": {
    "@glion/builder": "workspace:*",
    "@glion/check-readme": "workspace:*",
    "@glion/parser": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/unist": "^3.0.3",
    "@vitest/coverage-v8": "4.1.2",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
