{
  "name": "glion",
  "version": "0.1.0",
  "description": "MLLP server dev tool — dev server with live TUI, production JSON-line events, hot reload",
  "keywords": [
    "cli",
    "dev-server",
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "mllp"
  ],
  "homepage": "https://www.rethinkhealth.io/hl7v2/docs",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": "rethinkhealth/hl7v2.git",
  "bin": {
    "glion": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rethinkhealth/hl7v2-mllp": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@rethinkhealth/hl7v2": "workspace:*",
    "@rethinkhealth/hl7v2-mllp-ack": "workspace:*",
    "@rethinkhealth/testing": "workspace:*",
    "@rethinkhealth/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "4.1.2",
    "execa": "^9.5.0",
    "ink-testing-library": "^4.0.0",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  },
  "optionalDependencies": {
    "chokidar": "^4.0.0",
    "cosmiconfig": "^9.0.0",
    "ink": "^5.0.0",
    "jiti": "^2.4.0",
    "react": "^18.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0"
}
