{
  "name": "@glion/cli",
  "version": "0.14.1",
  "description": "MLLP server dev tool — dev server with live TUI, production JSON-line events, hot reload",
  "keywords": [
    "cli",
    "dev-server",
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "mllp"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/glion"
  },
  "bin": {
    "glion": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/run.d.ts",
  "exports": {
    ".": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@glion/mllp": "workspace:*",
    "rolldown": "1.0.0-rc.14",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@glion/hl7v2": "workspace:*",
    "@glion/mllp-ack": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "4.1.2",
    "execa": "^9.5.0",
    "ink-testing-library": "^4.0.0",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  },
  "optionalDependencies": {
    "chokidar": "^4.0.0",
    "ink": "^5.0.0",
    "react": "^18.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0"
}
