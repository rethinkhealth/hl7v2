{
  "name": "@glion/config",
  "version": "0.15.3",
  "description": "Configuration schema and loader for hl7v2",
  "keywords": [
    "config",
    "configuration",
    "hl7v2",
    "schema",
    "settings"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/config"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema.json": "./schema.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly && pnpm build:schema",
    "build:schema": "node --input-type=module -e \"import{writeFileSync}from'fs';import{jsonSchema}from'./dist/json-schema.js';writeFileSync('schema.json',JSON.stringify(jsonSchema,null,2));\"",
    "check-types": "tsc --noEmit",
    "check:readme": "glion-check-readme",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "publint": "publint --strict"
  },
  "dependencies": {
    "@glion/utils": "workspace:*",
    "cosmiconfig": "9.0.1",
    "unified": "11.0.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@glion/check-readme": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vitest": "4.1.2",
    "zod-to-json-schema": "3.25.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
