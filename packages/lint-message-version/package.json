    "@glion/builder": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/unist": "^3.0.3",
    "@vitest/coverage-v8": "4.1.2",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18"
