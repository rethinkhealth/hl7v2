{
  "name": "@glion/lint-max-message-size",
  "version": "0.15.3",
  "description": "hl7v2-lint rule to warn when message size exceeds the maximum allowed size",
  "keywords": [
    "definition",
    "hl7",
    "hl7v2",
    "hl7v2-lint",
    "hl7v2-lint-rule",
    "lint",
    "nodejs",
    "rule",
    "typescript"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/lint-max-message-size"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "check:readme": "glion-check-readme",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "publint": "publint --strict"
  },
  "dependencies": {
    "pluralize": "8.0.0",
    "unified": "11.0.5",
    "unified-lint-rule": "3.0.1",
    "unist-util-visit": "5.1.0",
    "unist-util-visit-parents": "6.0.2"
  },
  "devDependencies": {
    "@glion/ast": "workspace:*",
    "@glion/builder": "workspace:*",
    "@glion/check-readme": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/pluralize": "^0.0.33",
    "@types/unist": "^3.0.3",
    "@vitest/coverage-v8": "4.1.2",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vfile": "^6.0.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
