{
  "name": "@glion/preset-annotate-profile-recommended",
  "version": "0.15.3",
  "description": "Preset bundling all HL7v2 profile annotation plugins",
  "keywords": [
    "annotate",
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "nodejs",
    "plugin",
    "preset",
    "profile",
    "typescript",
    "unified"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/preset-annotate-profile-recommended"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "check:readme": "glion-check-readme",
    "bench": "vitest bench --run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "publint": "publint --strict"
  },
  "dependencies": {
    "@glion/annotate-profile-context": "workspace:*",
    "@glion/annotate-profile-datatypes": "workspace:*",
    "@glion/annotate-profile-fields": "workspace:*",
    "@glion/annotate-profile-fields-code-systems": "workspace:*",
    "@glion/annotate-profile-segments": "workspace:*",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@glion/ast": "workspace:*",
    "@glion/builder": "workspace:*",
    "@glion/check-readme": "workspace:*",
    "@glion/profiles": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
