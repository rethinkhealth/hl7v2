{
  "name": "@glion/preset-lint-recommended",
  "version": "0.15.3",
  "description": "hl7v2-lint preset with recommended rules",
  "keywords": [
    "definition",
    "hl7",
    "hl7v2",
    "hl7v2-lint",
    "hl7v2-lint-rule",
    "lint",
    "nodejs",
    "rule",
    "typescript"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/preset-lint-recommended"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "check:readme": "glion-check-readme",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "publint": "publint --strict"
  },
  "dependencies": {
    "@glion/lint-message-version": "workspace:*",
    "@glion/lint-no-trailing-empty-field": "workspace:*",
    "@glion/lint-required-message-header": "workspace:*",
    "@glion/lint-segment-header-length": "workspace:*",
    "unified": "11.0.5",
    "unified-lint-rule": "3.0.1"
  },
  "devDependencies": {
    "@glion/ast": "workspace:*",
    "@glion/builder": "workspace:*",
    "@glion/check-readme": "workspace:*",
    "@glion/jsonify": "workspace:*",
    "@glion/parser": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/unist": "^3.0.3",
    "@vitest/coverage-v8": "4.1.2",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vfile": "^6.0.3",
    "vfile-reporter": "^8.1.1",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
