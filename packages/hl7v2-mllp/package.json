{
  "name": "@rethinkhealth/hl7v2-mllp",
  "version": "0.7.1",
  "description": "Transport-agnostic MLLP (Minimal Lower Layer Protocol) engine for HL7v2 messaging",
  "keywords": [
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "mllp",
    "nodejs",
    "streaming",
    "typescript"
  ],
  "homepage": "https://www.rethinkhealth.io/hl7v2/docs",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": "rethinkhealth/hl7v2.git",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "bench": "vitest bench --run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rethinkhealth/hl7v2-ast": "workspace:*",
    "@rethinkhealth/hl7v2-parser": "workspace:*",
    "@rethinkhealth/hl7v2-util-query": "workspace:*",
    "vfile": "6.0.3"
  },
  "devDependencies": {
    "@rethinkhealth/testing": "workspace:*",
    "@rethinkhealth/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.0.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0"
}
