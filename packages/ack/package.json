{
  "name": "@glion/ack",
  "version": "0.15.0",
  "description": "HL7v2 acknowledgment message builder and typed error classes",
  "keywords": [
    "ack",
    "health",
    "healthcare",
    "hl7",
    "hl7v2",
    "nodejs",
    "typescript"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/ack"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@glion/ast": "workspace:*",
    "@glion/builder": "workspace:*",
    "@glion/util-query": "workspace:*",
    "@glion/util-timestamp": "workspace:*",
    "nanoid": "5.1.7"
  },
  "devDependencies": {
    "@glion/testing": "workspace:*",
    "@glion/to-hl7v2": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0"
}
