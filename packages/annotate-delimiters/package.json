{
  "name": "@glion/annotate-delimiters",
  "version": "0.14.1",
  "description": "Unified plugin to annotate file.data with HL7v2 delimiters derived from MSH-1/MSH-2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/annotate-delimiters"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@glion/util-query": "workspace:*"
  },
  "devDependencies": {
    "@glion/ast": "workspace:*",
    "@glion/builder": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@glion/utils": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
