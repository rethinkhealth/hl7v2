{
  "name": "@glion/preset-lint-profile-recommended",
  "version": "0.15.3",
  "description": "hl7v2-lint preset with profile-based validation rules",
  "keywords": [
    "hl7",
    "hl7v2",
    "hl7v2-lint",
    "lint",
    "nodejs",
    "profile",
    "typescript"
  ],
  "homepage": "https://glion.dev",
  "license": "MIT",
  "author": {
    "name": "Melek Somai",
    "email": "melek@rethinkhealth.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rethinkhealth/glion.git",
    "directory": "packages/preset-lint-profile-recommended"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit",
    "check:readme": "glion-check-readme",
    "bench": "vitest bench --run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "publint": "publint --strict"
  },
  "dependencies": {
    "@glion/annotate-profile-context": "workspace:*",
    "@glion/lint-profile-events-segments-order": "workspace:*",
    "@glion/lint-profile-extra-components": "workspace:*",
    "@glion/lint-profile-extra-fields": "workspace:*",
    "@glion/lint-profile-field-max-length": "workspace:*",
    "@glion/lint-profile-field-repetition": "workspace:*",
    "@glion/lint-profile-required-components": "workspace:*",
    "@glion/lint-profile-required-fields": "workspace:*",
    "@glion/lint-profile-table-values": "workspace:*",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@glion/ast": "workspace:*",
    "@glion/builder": "workspace:*",
    "@glion/check-readme": "workspace:*",
    "@glion/profiles": "workspace:*",
    "@glion/testing": "workspace:*",
    "@glion/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
