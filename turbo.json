{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "//#format": {},
    "//#lint": {
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "bench": {
      "cache": false,
      "passThroughEnv": [
        "CODSPEED_ENV",
        "CODSPEED_RUNNER_MODE",
        "CODSPEED_PROFILE_FOLDER"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
